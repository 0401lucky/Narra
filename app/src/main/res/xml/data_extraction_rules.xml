<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="datastore/" />
        <exclude domain="database" path="chat.db" />
        <exclude domain="database" path="chat.db-shm" />
        <exclude domain="database" path="chat.db-wal" />
        <exclude domain="sharedpref" path="secure_settings.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="datastore/" />
        <exclude domain="database" path="chat.db" />
        <exclude domain="database" path="chat.db-shm" />
        <exclude domain="database" path="chat.db-wal" />
        <exclude domain="sharedpref" path="secure_settings.xml" />
    </device-transfer>
</data-extraction-rules>
